# ─────────────────────────────────────────────────────────────
# Mpower Fitness Backend — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development   # development | production

PORT=5000

# ── Database ──────────────────────────────────────────────────
# Local dev (SQLite — no setup required)
SQLITE_PATH=./data/mpower.sqlite

# Production (PostgreSQL — uncomment and fill)
# DATABASE_URL=postgresql://user:strong_password@host:5432/mpower_fitness
# DB_SSL=true

# ── JWT — CHANGE THESE IN PRODUCTION ─────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_EXPIRE=2h
JWT_REFRESH_EXPIRE=7d

BCRYPT_ROUNDS=12   # 10 for dev speed, 12+ for production

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://yourdomain.com

# ── Redis (optional — app works without it) ───────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://user:password@your-redis-host:6379   # production

# ── UPI Payment Defaults ─────────────────────────────────────
# These can be overridden from the admin panel
UPI_ID=payments@yourcompany
UPI_NAME=Your Company Name

# ── File Uploads (optional S3) ────────────────────────────────
# Leave empty to use local disk storage
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=ap-south-1
