# ─────────────────────────────────────────────────────────────
# Mpower Fitness Frontend — Environment Variables
# Copy to .env for local dev, .env.production for builds
# ─────────────────────────────────────────────────────────────

# Backend API base URL
REACT_APP_API_URL=http://localhost:5000/api

# Socket.io server URL (usually same as backend)
REACT_APP_SOCKET_URL=http://localhost:5000

# Dev server bind address (use 127.0.0.1 if 0.0.0.0 is blocked)
HOST=127.0.0.1

# Set to "true" to force mock API (no backend needed)
# REACT_APP_USE_MOCK=false
