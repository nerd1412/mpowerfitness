# ==================== BACKEND ====================
NODE_ENV=development
PORT=5000

# Database
# Development defaults to SQLite (auto-created) — no extra services required.
SQLITE_PATH=./data/mpower.sqlite
# Production example:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=change_this_to_a_very_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_this_to_another_very_long_random_secret
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
BCRYPT_ROUNDS=12

# CORS
FRONTEND_URL=http://localhost:3000

# ── UPI PAYMENTS ──────────────────────────────────
# Your UPI VPA (Virtual Payment Address) registered with your bank
UPI_ID=yourname@bankname
UPI_NAME=Your Business Name

# ==================== FRONTEND ====================
REACT_APP_API_URL=http://localhost:5000/api
